# Copy this file to `.env` (which is gitignored) and fill in your values.
# Astro loads .env into the Airflow containers on `astro dev start`.

# Your username. Picks the airflow_<name> schema your DAG writes into.
AIRFLOW_STUDENT=yourname

# The azure_pg Airflow Connection is easiest to add from the Airflow UI
# (Admin -> Connections) rather than here, so its password never lands in a
# file. If you prefer env config, set a connection URI instead and reference
# it from your DAG. Never commit real credentials.
# AIRFLOW_CONN_AZURE_PG=postgresql://<user>:<password>@hyf-data-pg.postgres.database.azure.com:5432/team1?sslmode=require
